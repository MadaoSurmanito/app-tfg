{
  "info": {
    "name": "KinEstilistas API",
    "_postman_id": "b3c3b6e4-kinestilistas-api",
    "description": "Colección para probar la API del TFG KinEstilistas",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (Credentials)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"admin@test.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/callback/credentials",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "callback", "credentials"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout"]
            }
          }
        },
        {
          "name": "Session",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/auth/session",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "session"]
            }
          }
        },
        {
          "name": "Register Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"cliente@test.com\",\n  \"name\": \"Cliente Test\",\n  \"password\": \"123456\",\n  \"company\": \"Mi Peluquería\",\n  \"phone\": \"600000000\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register-request",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register-request"]
            }
          }
        }
      ]
    },
